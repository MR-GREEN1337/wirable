# Public backend URL — inlined into the client bundle at build time.
# Used by every "use client" component (NEXT_PUBLIC_ prefix is required for
# the value to be available in the browser).
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Server-only backend URL — used by server components and the NextAuth callbacks.
# In docker-compose this is the internal service name (http://backend:8000).
BACKEND_URL=http://localhost:8000

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret

# Google OAuth (sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (repo connect)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

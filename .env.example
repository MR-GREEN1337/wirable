# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agentready

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-prod
NEXTAUTH_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (for client connect) ────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Daytona (sandbox orchestration) ───────────────────────────────────────────
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=https://app.daytona.io

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Powers: OpenCode in Daytona (audit + fix agents), the CATTS arbiter, sourcing,
# enrichment, and email personalization.
# Paste your pool of keys here as a COMMA-SEPARATED list. The key pool shuffles
# the order at startup and rotates per run (round-robin) so load spreads evenly.
# Single key also works (ANTHROPIC_API_KEY below) as a fallback.
ANTHROPIC_API_KEYS=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Autonomous scout (sourcing → enrich → audit → outbound) ───────────────────
SCOUT_ENABLED=false          # set true to run the autonomous loop on a schedule
SCOUT_INTERVAL_MINUTES=30
SCOUT_BATCH_SIZE=3

# ── Outbound (Unipile) ────────────────────────────────────────────────────────
# DSN = host:port from your Unipile dashboard (e.g. api49.unipile.com:13049)
UNIPILE_DSN=
# API key from Unipile dashboard (separate from DSN)
UNIPILE_API_KEY=
# Account ID of the connected mailbox to send from
UNIPILE_ACCOUNT_ID=
SENDING_EMAIL=outbound@yourdomain.com
SENDING_DOMAIN=yourdomain.com

# ── Internals ─────────────────────────────────────────────────────────────────
INTERNAL_SECRET=change-me-in-prod
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
REPORT_BASE_URL=http://localhost:3000
